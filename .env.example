# Image tag (set by CI, or use 'latest' for local)
IMAGE_TAG=latest

# Google OAuth (used by agentgateway for JWT validation)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Jackett
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=your-jackett-api-key

# TMDB
TMDB_API_KEY=your-tmdb-api-key

# Transmission
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_PATH=/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASS=
TRANSMISSION_SSL=false

# WebDAV (Keenetic router storage)
WEBDAV_URL=https://segaa.keenetic.link/webdav/
WEBDAV_USER=admin
WEBDAV_PASS=your-webdav-password
